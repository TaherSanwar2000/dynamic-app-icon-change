<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.INTERNET" />

  <application
    android:name=".MainApplication"
    android:label="@string/app_name"
    android:allowBackup="false"
    android:theme="@style/AppTheme"
    android:supportsRtl="true"
    android:usesCleartextTraffic="${usesCleartextTraffic}">

    <!-- REAL ACTIVITY (NO LAUNCHER) -->
    <activity
      android:name=".MainActivity"
      android:exported="true"
      android:launchMode="singleTask"
      android:windowSoftInputMode="adjustResize"
      android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode" />

    <!-- DEFAULT ICON (MANDATORY FOR LIB) -->
    <activity-alias
      android:name=".MainActivityDefault"
      android:enabled="true"
      android:exported="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:targetActivity=".MainActivity">

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity-alias>

    <!-- GUITAR ICON -->
    <activity-alias
      android:name=".MainActivityGuitar"
      android:enabled="false"
      android:exported="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher_guitar"
      android:targetActivity=".MainActivity">

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity-alias>

    <!-- PIANO ICON -->
    <activity-alias
      android:name=".MainActivityPiano"
      android:enabled="false"
      android:exported="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher_piano"
      android:targetActivity=".MainActivity">

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity-alias>

    <!-- VIOLIN ICON -->
     <activity-alias
      android:name=".MainActivityViolin"
      android:enabled="false"
      android:exported="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher_violin"
      android:targetActivity=".MainActivity">

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity-alias>

    <!-- DRUM ICON -->
     <activity-alias
      android:name=".MainActivityDrum"
      android:enabled="false"
      android:exported="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher_drum"
      android:targetActivity=".MainActivity">

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity-alias>

  </application>
</manifest>
